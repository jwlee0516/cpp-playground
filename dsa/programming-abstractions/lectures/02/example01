#include <iostream>
using namespace std;

void zeroItOut(int& n) 
{
    n++;
}

int main()
{
    int n = 3;
    zeroItOut(n);

    // This prints 4. The ++ operator in zeroItOut() increments n back in main(),
    // since zeroItOut()'s copy of n is tied directly to this one.
    cout << n << endl;
    return 0;
}

