{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++ build (all cpp in folder)",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++20",
        "-Wall",
        "-Wextra",
        "-O2",
        "-g",
        "*.cpp",
        "-o",
        "app"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}